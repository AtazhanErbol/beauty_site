# ==========================================================================
#  Beauty Site — пример файла окружения.
#  Скопируйте в `.env` и заполните значения.
#  Для dev-режима по умолчанию НИЧЕГО менять не нужно.
# ==========================================================================

# ---- Основное ----
DJANGO_DEBUG=True
# Сгенерируйте свой ключ, например:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-in-production

# ---- Прод-настройки (при DEBUG=False) ----
DJANGO_ALLOWED_HOSTS=example.com,www.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com
DJANGO_SECURE_SSL_REDIRECT=True

# ---- Email (SMTP) ----
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# Для реальной отправки:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=you@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=Beauty Master <noreply@example.com>
ADMIN_EMAIL=master@example.com

